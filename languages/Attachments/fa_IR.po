#: Attachments.php:46
msgctxt "Setting Description"
msgid "Determines the default status of the new attachment comments."
msgstr "وضعیت پیش‌فرض دیدگاه‌ها در پیوست تازه را تعیین می‌کند."

#: Attachments.php:49
msgctxt "Setting Title"
msgid "Comment Control"
msgstr "کنترل دیدگاه‌ها"

#: Attachments.php:50
msgctxt "Setting Description"
msgid "Displays comments status check-box for each attachment."
msgstr "جعبه‌انتخاب وضعیت دیدگاه‌ها را برای هر پیوست نمایش می‌دهد."

#: Attachments.php:54
msgctxt "Setting Title"
msgid "Auto Rotation"
msgstr "چرخش خودکار"

#. translators: `%s`: `EXIF`
#: Attachments.php:57
#, php-format
msgctxt "Setting Description"
msgid "Fixes the rotation of JPEG images using %s extension, immediately after the upload."
msgstr "بلافاصله پس از بارگزاری، چرخش تصاویر JPEG را با استفاده از افزونه %s اصلاح می‌کند."

#. translators: `%s`: `alt`
#: Attachments.php:65
#, php-format
msgctxt "Setting Title"
msgid "Fallback %s to Title"
msgstr "پس‌نشینی %s به عنوان"

#: Attachments.php:68
msgctxt "Setting Description"
msgid "Tries to fill empty alt attribute with attachment title on images."
msgstr "برای پر کردن ویژگی alt خالی به کمک عنوان پیوست تلاش می‌کند."

#: Attachments.php:75
msgctxt "Setting Title"
msgid "Rewrite Permalinks"
msgstr "بازنویسی پایاپیوندها"

#: Attachments.php:76
msgctxt "Setting Description"
msgid "Changes default permalinks into attachment id."
msgstr "پایاپیوندهای پیش‌فرض را به شناسه پیوست تغییر می‌دهد."

#: Attachments.php:81
msgctxt "Setting Title"
msgid "Prefix Permalinks"
msgstr "پیشوند پایاپیوندها"

#: Attachments.php:82
msgctxt "Setting Description"
msgid "Adds to the permalink of attachments, before id."
msgstr "به پایاپیوند پیوست‌ها، پس از شناسه، افزوده می‌شود."

#: Attachments.php:91
msgctxt "Setting Title"
msgid "Attachment Count"
msgstr "شمار پیوست‌ها"

#: Attachments.php:92
msgctxt "Setting Description"
msgid "Displays attachment summary of the post."
msgstr "نمایش گزارش پیوست‌های نوشته."

#: Attachments.php:94
msgctxt "Setting Description"
msgid "Enhances author restrictions on media library list view."
msgstr "در نمای فهرست کتابخانه رسانه‌ای، امکان محدودیت بر اساس نویسندگان را اضافه می‌کند."

#: Attachments.php:97
msgctxt "Setting Title"
msgid "Restrict Library"
msgstr "محدودسازی کتاب‌خانه"

#: Attachments.php:98
msgctxt "Setting Description"
msgid "Restricts Media Library access to user's own uploads."
msgstr "در نمای فهرست کتابخانه رسانه‌ای، هر کاربر را محدود به پرونده‌های خودش می‌کند."

#: Attachments.php:106
msgctxt "Setting Title"
msgid "ShortCode Caption"
msgstr "برنگاشت شورت‌کد"

#: Attachments.php:107
msgctxt "Setting Description"
msgid "Displays the attachment caption after each item on the list."
msgstr "در فهرست، بعد از هر مورد برنگاشت پیوست را نمایش می‌دهد."

#: Attachments.php:111
msgctxt "Setting Title"
msgid "ShortCode Description"
msgstr "توضیحات شورت‌کد"

#: Attachments.php:112
msgctxt "Setting Description"
msgid "Displays the attachment description after each item on the list."
msgstr "در فهرست، بعد از هر مورد توضیحات پیوست را نمایش می‌دهد."

