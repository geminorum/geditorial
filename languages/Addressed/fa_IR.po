#: Addressed.php:41
msgctxt "Setting Title"
msgid "Base Country"
msgstr "کشور پایه"

#: Addressed.php:42
msgctxt "Setting Description"
msgid "Defines the base country of site for supported contents."
msgstr "کشور پایه سایت را برای محتوای پشتیبانی‌شده تعریف می‌کند."

#: Addressed.php:49
msgctxt "Setting Title"
msgid "Base Province"
msgstr "استان پایه"

#: Addressed.php:50
msgctxt "Setting Description"
msgid "Defines the base state or province of site for supported contents."
msgstr "استان پایه سایت را برای محتوای پشتیبانی‌شده تعریف می‌کند."

#: Addressed.php:59
msgctxt "Setting Title"
msgid "Default Format"
msgstr "ساختار پیش‌فرض"

#: Addressed.php:60
msgctxt "Setting Description"
msgid "Defines the default address format for supported contents."
msgstr "ساخار پیش‌فرض نشانی را برای محتوای پشتیبانی‌شده تعریف می‌کند."

#: Addressed.php:66
msgctxt "Setting Title"
msgid "Override Base Country"
msgstr "رونویسی کشور پایه"

#: Addressed.php:67
msgctxt "Setting Description"
msgid "Also overrides the address format of the base country of site."
msgstr "همچنین ساختار نشانی کشور پایه سایت را رونویسی می‌کند."

#: Addressed.php:72
msgctxt "Setting Title"
msgid "Override Woo-Commerce"
msgstr "رونویسی ووکامرس"

#: Addressed.php:73
msgctxt "Setting Description"
msgid "Also overrides the default format of Woo-Commerce adressess."
msgstr "همچنین ساختار پیش‌فرض نشانی‌های ووکامرس را رونویسی می‌کند."

#: Addressed.php:81
msgctxt "Setting Title"
msgid "Address Types"
msgstr "انواع نشانی"

#: Addressed.php:86
msgctxt "Setting Title"
msgid "Title"
msgstr "عنوان"

#: Addressed.php:87
msgctxt "Setting Description"
msgid "Defines the title on the address type."
msgstr "عنوان نوع نشانی را تعریف می‌کند."

#: Addressed.php:92
msgctxt "Setting Title"
msgid "Description"
msgstr "توضیحات"

#: Addressed.php:93
msgctxt "Setting Description"
msgid "Defines the description on the address type."
msgstr "توضیحات نوع نشانی را تعریف می‌کند."

#: Addressed.php:98
msgctxt "Setting Title"
msgid "Identifier"
msgstr "شناساگر"

#: Addressed.php:99
msgctxt "Setting Description"
msgid "Defines the unique identifier on the address type."
msgstr "شناساگر یکتا برای نوع نشانی تعریف می‌کند."

#: Addressed.php:106
msgctxt "Setting Title"
msgid "Priority"
msgstr "اولویت"

#: Addressed.php:107
msgctxt "Setting Description"
msgid "Sets as the sort priority where the address display on the list."
msgstr "به‌عنوان اولویت مرتب‌سازی تنظیم می‌کند که نشانی در فهرست کجا نمایش داده شود."

#: Addressed.php:116
msgctxt "Setting Title"
msgid "Supported Fields"
msgstr "فیلدهای پشتیبانی‌شده"

#: Addressed.php:117
msgctxt "Setting Description"
msgid "Defines supported address fields for all type."
msgstr "فیلد نشانی پشتیبانی‌شده برای تمامی انواع را تعریف می‌کند."

#: Addressed.php:118
msgctxt "Setting Empty String"
msgid "There are no address fields available!"
msgstr "هیچ فیلد نشانی در دسترس نیست!"

#: Addressed.php:149
msgctxt "Control label"
msgid "Address line 1"
msgstr "خط اول نشانی"

#: Addressed.php:150
msgctxt "Control Description"
msgid "The street address for the location."
msgstr "نشانی خیابان محل مورد نظر شما."

#: Addressed.php:155
msgctxt "Control label"
msgid "Address Line 2"
msgstr "خط دوم نشانی"

#: Addressed.php:156
msgctxt "Control Description"
msgid "An additional, optional address line for the location."
msgstr "خط نشانی افزوده و اختیاری، برای محل مورد نظر شما."

#: Addressed.php:161
msgctxt "Control label"
msgid "Company"
msgstr "شرکت"

#: Addressed.php:162
msgctxt "Control Description"
msgid "The organization in which this address is located."
msgstr "سازمانی که این نشانی در آن قرار دارد."

#: Addressed.php:167
msgctxt "Control label"
msgid "City"
msgstr "شهر"

#: Addressed.php:168
msgctxt "Control Description"
msgid "The city in which this address is located."
msgstr "شهری که نشانی شما در آن واقع شده است."

#: Addressed.php:173
msgctxt "Control label"
msgid "Province"
msgstr "استان"

#: Addressed.php:174
msgctxt "Control Description"
msgid "The state or province in which this address is located."
msgstr "استانی که نشانی شما در آن واقع شده است."

#: Addressed.php:179
msgctxt "Control label"
msgid "Country"
msgstr "کشور"

#: Addressed.php:180
msgctxt "Control Description"
msgid "The country in which this address is located."
msgstr "کشوری که نشانی شما در آن واقع شده است."

#: Addressed.php:185
msgctxt "Control label"
msgid "Coordinates"
msgstr "مختصات جغرافیایی"

#: Addressed.php:186
msgctxt "Control Description"
msgid "The Latitude and Longitude to this address."
msgstr "طول و عرض جغرافیایی برای این نشانی."

#: Addressed.php:191
msgctxt "Control label"
msgid "Site URL"
msgstr "نشانی سایت"

#: Addressed.php:192
msgctxt "Control Description"
msgid "The site URL of this address."
msgstr "URL سایت این نشانی."

#: Addressed.php:197
msgctxt "Control label"
msgid "Embed URL"
msgstr "نشانه جاساز"

#: Addressed.php:198
msgctxt "Control Description"
msgid "An embeddable resource URL about this address."
msgstr "URL یک منبع جاساز درباره این نشانی."

#. translators: `%s`: address type title
#: Addressed.php:241
#, php-format
msgctxt "Customizer: Section Title"
msgid "Address: %s"
msgstr "نشانی %s"

#: Addressed.php:385
msgctxt "Header"
msgid "Address Reports"
msgstr "گزارش‌های نشانی"

#: ModuleSettings.php:16
msgctxt "Card Title"
msgid "Untitled Address Type"
msgstr "نوع نشانی بدون عنوان"

#. translators: `%s`: site URL title
#: ModuleSettings.php:42
#, php-format
msgctxt "Button"
msgid "Visit the website on &#8220;%s&#8221;"
msgstr "وب‌سایت &laquo;%s&raquo; را ببینید"

